{
  "name": "hytale-save-editor-ui",
  "version": "1.0.9",
  "description": "Electron GUI for Hytale Save Editor",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "vite": "vite",
    "electron": "wait-on tcp:13337 && electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.284.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "electron": "^25.1.1",
    "electron-builder": "^24.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.1.3",
    "vite": "^4.3.9",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.dxrmy.hytale-save-editor",
    "productName": "Hytale Save Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/hse.py",
        "to": "hse.py"
      },
      {
        "from": "electron/get_dynamic_assets.py",
        "to": "get_dynamic_assets.py"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
